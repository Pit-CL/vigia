# Credenciales de la API de la Dirección Meteorológica de Chile (opcional).
# Sin esto la app igual funciona: las observaciones llegan por METAR (NOAA,
# sin clave). Con esto se añaden 10 estaciones automáticas (EMA) de V/RM.
#
# Registro gratuito: https://climatologia.meteochile.gob.cl
# Copia este archivo a .env y completa tus valores. NUNCA subas .env al repo.

DMC_USUARIO=tu-correo@ejemplo.cl
DMC_TOKEN=tu-token-de-la-dmc

# Clave de la capa de incendios activos (NASA FIRMS).
# Registro gratuito: https://firms.modaps.eosdis.nasa.gov/api/
# Sin ella la capa queda dormida (0 focos, sin error).
FIRMS_MAP_KEY=tu-map-key-de-firms

# Credenciales de la capa de precios de combustible (CNE, Bencina en Línea,
# API v4 con login dinámico). Registro gratuito: https://api.cne.cl
# Sin ambas la capa queda dormida (0 estaciones, sin error).
CNE_EMAIL=tu-correo@ejemplo.cl
CNE_PASSWORD=tu-password-de-cne

# Claves VAPID para Web Push (notificaciones de emergencia). Se generan UNA
# sola vez con: docker compose run --rm push python3 /app/push/genkeys.py
# Copia las dos líneas que imprime tal cual a este archivo.
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CONTACT=

# Puerto local donde nginx expone el sitio (127.0.0.1:PUERTO). Opcional,
# default 8100 (libre en este VPS). Solo cámbialo si el 8100 ya está
# ocupado por otro servicio en la máquina donde despliegues.
VIGIA_HTTP_PORT=8100
